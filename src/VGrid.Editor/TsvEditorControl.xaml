<UserControl x:Class="VGrid.Editor.TsvEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VGrid.Views"
             xmlns:converters="clr-namespace:VGrid.Converters"
             PreviewKeyDown="UserControl_PreviewKeyDown">

    <UserControl.Resources>
        <converters:RowIndexToBrushConverter x:Key="RowIndexToBrushConverter"/>
        <converters:ColumnIndexToBrushConverter x:Key="ColumnIndexToBrushConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:ModeToColorConverter x:Key="ModeToColorConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DataGrid -->
        <Border Grid.Row="0" BorderThickness="0">
            <DataGrid x:Name="TsvGrid"
                      ItemsSource="{Binding GridViewModel.Rows}"
                      AlternationCount="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="False"
                      CanUserResizeColumns="False"
                      CanUserResizeRows="False"
                      IsReadOnly="False"
                      SelectionMode="Extended"
                      SelectionUnit="Cell"
                      DataContextChanged="TsvGrid_OnDataContextChanged"
                      BeginningEdit="TsvGrid_BeginningEdit"
                      CellEditEnding="TsvGrid_CellEditEnding"
                      HeadersVisibility="All"
                      Focusable="False"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      Background="{DynamicResource DataGridBackgroundBrush}"
                      Foreground="{DynamicResource DataGridForegroundBrush}"
                      RowBackground="{DynamicResource DataGridRowBackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource DataGridRowBackgroundBrush}"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="{DynamicResource DataGridGridLinesBrush}"
                      VerticalGridLinesBrush="{DynamicResource DataGridGridLinesBrush}"
                      RowHeaderWidth="40"
                      ColumnHeaderHeight="25"
                      BorderBrush="{DynamicResource DataGridBorderBrush}"
                      BorderThickness="1"
                      FontFamily="Segoe UI"
                      FontSize="11"
                      Loaded="TsvGrid_Loaded"
                      Margin="0">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource ColumnIndexToBrushConverter}">
                                    <Binding Path="Column.DisplayIndex" RelativeSource="{RelativeSource Self}"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" Path="DataContext.VimState.CursorPosition.Column"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="{DynamicResource DataGridHeaderForegroundBrush}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource DataGridBorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding" Value="5,3"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ColumnHeader_PreviewMouseLeftButtonDown"/>
                        <EventSetter Event="PreviewMouseMove" Handler="ColumnHeader_PreviewMouseMove"/>
                        <EventSetter Event="PreviewMouseLeftButtonUp" Handler="ColumnHeader_PreviewMouseLeftButtonUp"/>
                        <EventSetter Event="MouseRightButtonUp" Handler="ColumnHeader_MouseRightButtonUp"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowHeaderStyle>
                    <Style TargetType="DataGridRowHeader">
                        <Setter Property="Background">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource RowIndexToBrushConverter}">
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="Item.Index"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" Path="DataContext.VimState.CursorPosition.Row"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="{DynamicResource DataGridHeaderForegroundBrush}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource DataGridBorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Width" Value="40"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="RowHeader_PreviewMouseLeftButtonDown"/>
                        <EventSetter Event="PreviewMouseMove" Handler="RowHeader_PreviewMouseMove"/>
                        <EventSetter Event="PreviewMouseLeftButtonUp" Handler="RowHeader_PreviewMouseLeftButtonUp"/>
                        <EventSetter Event="MouseRightButtonUp" Handler="RowHeader_MouseRightButtonUp"/>
                    </Style>
                </DataGrid.RowHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{DynamicResource DataGridRowBackgroundBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.ContextMenu>
                    <ContextMenu Opened="ContextMenu_Opened">
                        <MenuItem Header="Cut" InputGestureText="Ctrl+X" Click="ContextMenu_Cut_Click"/>
                        <MenuItem Header="Copy" InputGestureText="Ctrl+C" Click="ContextMenu_Copy_Click"/>
                        <MenuItem x:Name="CopyAsMarkdownTableMenuItem"
                                  Header="マークダウンの表としてコピー"
                                  Visibility="Collapsed"
                                  Click="ContextMenu_CopyAsMarkdownTable_Click"/>
                        <MenuItem Header="Paste" InputGestureText="Ctrl+V" Click="ContextMenu_Paste_Click"/>
                        <Separator/>
                        <MenuItem Header="Delete" InputGestureText="Del" Click="ContextMenu_Delete_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- Selected Cell Content Preview -->
        <Border Grid.Row="1"
                Background="{DynamicResource DataGridBackgroundBrush}"
                BorderBrush="{DynamicResource DataGridBorderBrush}"
                BorderThickness="0,1,0,0"
                MaxHeight="80"
                MinHeight="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding PositionText}"
                           Foreground="{DynamicResource DataGridHeaderForegroundBrush}"
                           Background="{DynamicResource DataGridHeaderBackgroundBrush}"
                           Padding="8,4"
                           MinWidth="60"
                           TextAlignment="Center"
                           VerticalAlignment="Stretch"
                           FontFamily="Segoe UI"
                           FontSize="12"/>
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding SelectedCellContent, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="{DynamicResource DataGridForegroundBrush}"
                             BorderThickness="0"
                             Padding="8,4"
                             TextWrapping="Wrap"
                             FontFamily="Segoe UI"
                             FontSize="12"
                             VerticalAlignment="Top"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Find/Replace Panel Overlay -->
        <views:FindReplacePanel Grid.Row="0"
                                DataContext="{Binding FindReplaceViewModel}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="20,10,20,0"
                                Panel.ZIndex="100"/>

        <!-- Command Palette Panel Overlay -->
        <views:CommandPalettePanel Grid.Row="0"
                                   DataContext="{Binding CommandPaletteViewModel}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="0,10,0,0"
                                   Panel.ZIndex="101"/>
    </Grid>

</UserControl>
